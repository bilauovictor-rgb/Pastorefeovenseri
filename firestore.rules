rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: sermons
    // Document ID: auto-generated
    // Fields:
    //   - title: string (required)
    //   - topic: string (optional)
    //   - goal: string (optional)
    //   - manuscript: string (optional)
    //   - blog: string (optional)
    //   - youtubeScript: string (optional)
    //   - socialPosts: string (optional)
    //   - email: string (optional)
    //   - excerpt: string (optional)
    //   - featuredImage: string (optional)
    //   - status: string (required, enum: draft, processed, scheduled, published)
    //   - createdAt: string (required, ISO 8601)
    //   - publishAt: string (optional, ISO 8601)
    //   - podcastAudioUrl: string (optional)
    //   - podcastAudioStatus: string (optional, enum: none, generating, ready, failed)
    //   - podcastGeneratedAt: string (optional, ISO 8601)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "officialgiganticcomputers@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidSermon(data) {
      return data.keys().hasAll(['title', 'status', 'createdAt']) &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.status in ['draft', 'processed', 'scheduled', 'published'] &&
             data.createdAt is string &&
             (!('topic' in data) || (data.topic is string && data.topic.size() < 500)) &&
             (!('goal' in data) || (data.goal is string && data.goal.size() < 1000)) &&
             (!('manuscript' in data) || (data.manuscript is string && data.manuscript.size() < 100000)) &&
             (!('blog' in data) || (data.blog is string && data.blog.size() < 50000)) &&
             (!('youtubeScript' in data) || (data.youtubeScript is string && data.youtubeScript.size() < 20000)) &&
             (!('socialPosts' in data) || (data.socialPosts is string && data.socialPosts.size() < 10000)) &&
             (!('email' in data) || (data.email is string && data.email.size() < 10000)) &&
             (!('excerpt' in data) || (data.excerpt is string && data.excerpt.size() < 1000)) &&
             (!('featuredImage' in data) || (data.featuredImage is string && data.featuredImage.size() < 1000)) &&
             (!('publishAt' in data) || (data.publishAt is string)) &&
             (!('podcastAudioUrl' in data) || (data.podcastAudioUrl is string)) &&
             (!('podcastAudioStatus' in data) || (data.podcastAudioStatus in ['none', 'generating', 'ready', 'failed'])) &&
             (!('podcastGeneratedAt' in data) || (data.podcastGeneratedAt is string));
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /sermons/{sermonId} {
      // Public can read published sermons
      allow read: if resource.data.status == 'published' || isAdmin();
      
      // Only admins can create, update, or delete
      allow create: if isAdmin() && isValidSermon(request.resource.data);
      allow update: if isAdmin() && isValidSermon(request.resource.data);
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      // Only admins can set roles
      allow create, update: if isAdmin();
    }

    match /{path=**} {
      allow read, write: if false;
    }
  }
}
